# Clinic login (any team member — same username/password)
ADMIN_USERNAME=v3dentalclinic@gmail.com
ADMIN_PASSWORD=v3clinic@123
JWT_SECRET=use-a-long-random-string-here

# Google Sheet ID from the sheet URL
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Option A: paste full service account JSON as one line (good for Vercel)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B: email + private key (good for local .env)
GOOGLE_SERVICE_ACCOUNT_EMAIL=dental-crm@v3-dental-lead-crm.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Calendar reminders (optional — uses same service account)
GOOGLE_CALENDAR_ID=primary

# Optional: calendar ID for dashboard embed iframe (defaults to clinic Gmail)
# VITE_CALENDAR_EMBED_ID=v3dentalclinic@gmail.com
